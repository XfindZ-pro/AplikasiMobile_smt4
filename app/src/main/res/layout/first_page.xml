<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FCF5F0"
    android:gravity="center"
    android:padding="24dp">

    <!-- Logo DonasiKu -->
    <ImageView
        android:id="@+id/logo_aplikasi"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="24dp"
        android:src="@mipmap/ic_launcher_round" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DonasiKu"
        android:textColor="#A020F0"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Transparansi dan Kepedulian\ndalam Genggaman"
        android:textColor="#4A4A4A"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="40dp"/>

    <!-- Indikator Halaman Sederhana -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">
        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#A020F0"
            android:layout_marginEnd="8dp"/>
        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#D1D1D1" />
    </LinearLayout>

    <Button
        android:id="@+id/button_first"
        android:layout_width="200dp"
        android:layout_height="55dp"
        android:text="NEXT"
        android:backgroundTint="#A020F0"
        android:textColor="#FFFFFF"
        app:cornerRadius="12dp" />

</LinearLayout>
