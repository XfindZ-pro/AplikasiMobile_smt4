<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp">

    <ImageView
        android:id="@+id/ivMedal"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_centerVertical="true"
        android:src="@android:drawable/btn_star_big_on"
        app:tint="#FFD700" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:layout_toEndOf="@id/ivMedal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNamaDonatur"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Donatur"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTransaksiCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 transaksi"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTotalDonasi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:text="Rp 0"
        android:textColor="@color/primary_purple"
        android:textStyle="bold" />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/ivMedal"
        android:layout_marginTop="12dp"
        android:background="#EEEEEE" />

</RelativeLayout>
